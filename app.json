{
  "expo": {
    "name": "Tracks&Taps",
    "slug": "tracks-and-taps",
    "version": "2.6.0",
    "orientation": "portrait",
    "icon": "./assets/images/AppIconColouredDarkTheme.png",
    "scheme": "tracks-taps",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "server"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joeypoel.trackstaps",
      "buildNumber": "7",
      "icon": {
        "light": "./assets/images/AppIconColouredWhiteTheme.png",
        "dark": "./assets/images/AppIconColouredDarkTheme.png",
        "tinted": "./assets/images/AppIconDarkTheme.png"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Tracks Taps uses your location to show your position on the map and verify location-based challenges.",
        "NSPhotoLibraryUsageDescription": "Tracks Taps needs access to your photo library to select images for tours and stops.",
        "NSPhotoLibraryAddUsageDescription": "Tracks Taps saves your captured challenge photos to your photo library.",
        "NSCameraUsageDescription": "Tracks Taps needs access to your camera to take photos for challenges and tour images.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/images/AppIconColouredDarkTheme.png"
      },
      "package": "com.joeypoel.trackstaps",
      "versionCode": 7,
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json"
    },
    "plugins": [
      "expo-router",
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Tracks & Taps to access your photos.",
          "savePhotosPermission": "Allow Tracks & Taps to save photos to your gallery."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/SplashScreenColouredWhiteTheme.png",
          "imageWidth": 1024,
          "imageHeight": 1024,
          "resizeMode": "contain",
          "backgroundColor": "#F8FAFC",
          "dark": {
            "image": "./assets/images/SplashScreenColouredDarkTheme.png",
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-font",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.200375813162-21etd79sc2q5276t3aer5c5f7kfg1aqb"
        }
      ],
      "expo-apple-authentication"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "033de2f9-fb8a-489a-8360-f4fb5f48540e"
      }
    },
    "owner": "tracks-and-taps"
  }
}