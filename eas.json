{
    "cli": {
        "version": ">= 10.0.0",
        "appVersionSource": "local"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "channel": "development"
        },
        "preview": {
            "android": {
                "buildType": "apk"
            },
            "channel": "preview",
            "env": {
                "NODE_OPTIONS": "--max-old-space-size=8192"
            }
        },
        "production": {
            "android": {
                "buildType": "app-bundle"
            },
            "channel": "production",
            "env": {
                "NODE_OPTIONS": "--max-old-space-size=8192"
            }
        }
    },
    "submit": {
        "production": {}
    }
}